{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "HyperCorn",
            "type": "debugpy",
            "justMyCode": false,
            "envFile": "${workspaceFolder}/../secret.env",
            "request": "launch",
            "program": "${workspaceFolder}/.venv/bin/hypercorn",
            "args": [
                "--bind",
                "0.0.0.0:8001",
                "--workers",
                "1",
                "--reload",
                "--log-level", "DEBUG",
                "nldi.asgi:APP",
            ]
        },
        {
            "name": "uvicorn",
            "type": "debugpy",
            "justMyCode": false,
            "envFile": "${workspaceFolder}/../secret.env",
            "request": "launch",
            "program": "${workspaceFolder}/.venv/bin/uvicorn",
            "args": [
                "--host", "0.0.0.0",
                "--port", "8001",
                "--workers",
                "1",
                "--reload",
                "--log-level", "debug",
                "nldi.asgi:APP",
            ]
        }

    ]
}
